# LandGuard Uganda — Crane Cloud PRODUCTION environment
#
# This is the national-rollout shape. Pilot ends; MoLHUD inherits stewardship.
# Two-person sign-off required for every change (see MAINTAINERS.md +
# docs/CUSTODY.md). The `BACKEND_IMAGE_TAG` deliberately starts BLANK so a
# careless deploy fails fast — production rolls only specific release tags.
#
# Copy to production.env (gitignored) and fill in real values.
#
#   cp production.env.example production.env
#   $EDITOR production.env
#
# Then deploy:
#   make -C infra/cranecloud deploy ENV=production    # first deploy ONLY
#   make -C infra/cranecloud update-backend ENV=production
#   make -C infra/cranecloud update-frontend ENV=production

# ── Crane Cloud project ──────────────────────────────────────────────────
CRANECLOUD_PROJECT_ID=

# ── Backend app ──────────────────────────────────────────────────────────
BACKEND_APP_NAME=landguard-backend
BACKEND_IMAGE=ghcr.io/mpairwe7/landguard-uganda-backend
# BLANK on purpose. Production deploys MUST set a specific release tag
# (e.g. v0.1.0). Never use `latest`.
BACKEND_IMAGE_TAG=
BACKEND_PORT=8000
BACKEND_REPLICAS=4                # scale further per docs/SLA_TARGETS.md §3
BACKEND_APP_ID=

# ── Frontend app ─────────────────────────────────────────────────────────
FRONTEND_APP_NAME=landguard-frontend
FRONTEND_IMAGE=ghcr.io/mpairwe7/landguard-uganda-frontend
FRONTEND_IMAGE_TAG=
FRONTEND_PORT=3000
FRONTEND_REPLICAS=4
FRONTEND_APP_ID=

# ── Application config ───────────────────────────────────────────────────
APP_ENV=production
APP_NAME=landguard-backend
LOG_LEVEL=INFO
DEMO_MODE=false                   # asserted at startup; production MUST be false

# ── Database (production-grade Postgres+PostGIS, replicas + WAL) ─────────
DB_BACKEND=postgres
POSTGRES_DSN=                     # via Crane Cloud secret manager — never paste here

# ── Cache & queue ────────────────────────────────────────────────────────
REDIS_URL=                        # via Crane Cloud secret manager

# ── Auth (OIDC via NITA-U IdP) ───────────────────────────────────────────
AUTH_MODE=oidc
JWT_HS256_SECRET=                 # via Crane Cloud secret manager
JWT_ISSUER=landguard.ug
JWT_AUDIENCE=landguard-backend
OIDC_JWKS_URL=                    # https://idp.nita.go.ug/.well-known/jwks.json

# ── Blockchain ───────────────────────────────────────────────────────────
# Pilot uses Sepolia; production migrates to the permissioned chain when
# commissioned. See docs/adr/0003-regional-chain-migration.md. Until then,
# production still runs on Sepolia (testnet) — there is no point putting
# anchors on Ethereum mainnet for the chain-migration window.
BLOCKCHAIN_PROVIDER=sepolia
SEPOLIA_RPC_URL=                  # via Crane Cloud secret manager
SEPOLIA_CHAIN_ID=11155111
REGISTRAR_PRIVATE_KEY=            # IDEALLY: via Crane Cloud secret manager + HSM-backed signer
CONTRACT_ADDRESS_FILE=/app/data_store/contract_address.json
ANCHOR_FLUSH_INTERVAL_SECONDS=300
ANCHOR_FLUSH_BATCH_SIZE=100

# ── Multi-sig 3-of-5 (REQUIRED for production) ───────────────────────────
MULTISIG_ENABLED=true

# ── NIRA (live) ──────────────────────────────────────────────────────────
NIRA_PROVIDER=live
NIRA_BASE_URL=
NIRA_API_KEY=                     # via Crane Cloud secret manager
NIRA_CACHE_TTL_SECONDS=86400

# ── PII encryption ───────────────────────────────────────────────────────
PII_ENCRYPTION_KEY=               # via Crane Cloud secret manager; rotated annually

# ── Rate limits ──────────────────────────────────────────────────────────
RATE_LIMIT_ANON=10/minute
RATE_LIMIT_AUTH=60/minute
RATE_LIMIT_ADMIN=300/minute
RATE_LIMIT_PUBLIC_VERIFY=20/minute

# ── Observability ────────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=      # NITA-U-operated collector
OTEL_SERVICE_NAME=landguard-backend
PROMETHEUS_METRICS_ENABLED=true

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=https://verify.landguard.ug,https://www.landguard.ug

# ── Frontend public config ───────────────────────────────────────────────
BACKEND_URL=https://api.landguard.ug
NEXT_PUBLIC_APP_NAME=LandGuard Uganda
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_DEFAULT_DISTRICT_ID=3
DEMO_TOKEN=                       # MUST be blank in production — demo gate is closed
