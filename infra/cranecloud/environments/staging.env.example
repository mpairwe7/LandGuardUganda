# LandGuard Uganda — Crane Cloud STAGING environment
#
# Copy to staging.env (gitignored) and fill in real values.
#
#   cp staging.env.example staging.env
#   $EDITOR staging.env
#
# Then deploy:
#   make -C infra/cranecloud deploy ENV=staging

# ── Crane Cloud project ──────────────────────────────────────────────────
CRANECLOUD_PROJECT_ID=

# ── Backend app ──────────────────────────────────────────────────────────
BACKEND_APP_NAME=landguard-backend-staging
BACKEND_IMAGE=ghcr.io/mpairwe7/landguard-uganda-backend
BACKEND_IMAGE_TAG=main
BACKEND_PORT=8000
BACKEND_REPLICAS=1
BACKEND_APP_ID=

# ── Frontend app ─────────────────────────────────────────────────────────
FRONTEND_APP_NAME=landguard-frontend-staging
FRONTEND_IMAGE=ghcr.io/mpairwe7/landguard-uganda-frontend
FRONTEND_IMAGE_TAG=main
FRONTEND_PORT=3000
FRONTEND_REPLICAS=1
FRONTEND_APP_ID=

# ── Application config ───────────────────────────────────────────────────
APP_ENV=staging
APP_NAME=landguard-backend
LOG_LEVEL=DEBUG
DEMO_MODE=true

# ── Database (Crane Cloud Postgres add-on OR external) ───────────────────
DB_BACKEND=postgres
POSTGRES_DSN=postgresql+asyncpg://landguard:landguard@postgres:5432/landguard_staging

# ── Cache & queue ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth (HS256 dev token; OIDC kicks in at pilot+) ──────────────────────
AUTH_MODE=dev
JWT_HS256_SECRET=                                # generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_ISSUER=landguard.ug
JWT_AUDIENCE=landguard-backend
OIDC_JWKS_URL=

# ── Blockchain (Sepolia testnet for staging) ─────────────────────────────
BLOCKCHAIN_PROVIDER=sepolia
SEPOLIA_RPC_URL=                                 # https://sepolia.infura.io/v3/<key> or Alchemy
SEPOLIA_CHAIN_ID=11155111
REGISTRAR_PRIVATE_KEY=                           # Sepolia-only test key; never a mainnet key
CONTRACT_ADDRESS_FILE=/app/data_store/contract_address.json
ANCHOR_FLUSH_INTERVAL_SECONDS=300
ANCHOR_FLUSH_BATCH_SIZE=100

# ── Multi-sig (off for staging; on for pilot+) ───────────────────────────
MULTISIG_ENABLED=false

# ── NIRA (mock for staging) ──────────────────────────────────────────────
NIRA_PROVIDER=mock
NIRA_BASE_URL=
NIRA_API_KEY=
NIRA_CACHE_TTL_SECONDS=86400

# ── PII encryption ───────────────────────────────────────────────────────
# Generate: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
PII_ENCRYPTION_KEY=

# ── Rate limits ──────────────────────────────────────────────────────────
RATE_LIMIT_ANON=20/minute
RATE_LIMIT_AUTH=120/minute
RATE_LIMIT_ADMIN=600/minute
RATE_LIMIT_PUBLIC_VERIFY=40/minute

# ── Observability ────────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=                     # Crane Cloud / NITA-U OTel collector
OTEL_SERVICE_NAME=landguard-backend-staging
PROMETHEUS_METRICS_ENABLED=true

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=https://landguard-frontend-staging.cranecloud.ug

# ── Frontend public config ───────────────────────────────────────────────
BACKEND_URL=https://landguard-backend-staging.cranecloud.ug
NEXT_PUBLIC_APP_NAME=LandGuard Uganda (staging)
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DEFAULT_DISTRICT_ID=3
DEMO_TOKEN=open-sesame-staging
