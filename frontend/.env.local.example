# Frontend env (Bun + Next.js 16)
NEXT_PUBLIC_APP_NAME=LandGuard Uganda
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DEFAULT_DISTRICT_ID=3

# When running via docker-compose, the backend service name resolves to "backend".
BACKEND_URL=http://backend:8000

# Demo Control Panel passcode (also gated by ?demo=1).
DEMO_TOKEN=open-sesame-2026
