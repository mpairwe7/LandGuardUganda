# LandGuard Uganda — Crane Cloud PILOT environment
#
# Copy to pilot.env (gitignored) and fill in real values.
#
#   cp pilot.env.example pilot.env
#   $EDITOR pilot.env
#
# Then deploy:
#   make -C infra/cranecloud deploy ENV=pilot

# ── Crane Cloud project ──────────────────────────────────────────────────
CRANECLOUD_PROJECT_ID=

# ── Backend app ──────────────────────────────────────────────────────────
BACKEND_APP_NAME=landguard-backend-pilot
BACKEND_IMAGE=ghcr.io/mpairwe7/landguard-uganda-backend
BACKEND_IMAGE_TAG=v0.1.0-showcase
BACKEND_PORT=8000
BACKEND_REPLICAS=2
BACKEND_APP_ID=

# ── Frontend app ─────────────────────────────────────────────────────────
FRONTEND_APP_NAME=landguard-frontend-pilot
FRONTEND_IMAGE=ghcr.io/mpairwe7/landguard-uganda-frontend
FRONTEND_IMAGE_TAG=v0.1.0-showcase
FRONTEND_PORT=3000
FRONTEND_REPLICAS=2
FRONTEND_APP_ID=

# ── Application config ───────────────────────────────────────────────────
APP_ENV=production            # the prod-safety asserter runs; pilot must satisfy it
APP_NAME=landguard-backend
LOG_LEVEL=INFO
# DEMO_MODE=false is REQUIRED for APP_ENV=production. The Mityana pilot
# audience uses the same surface as production citizens.
DEMO_MODE=false

# ── Database ─────────────────────────────────────────────────────────────
DB_BACKEND=postgres
POSTGRES_DSN=                                    # postgresql+asyncpg://landguard:<pw>@<host>:5432/landguard_pilot

# ── Cache & queue ────────────────────────────────────────────────────────
REDIS_URL=                                       # redis://<host>:6379/0

# ── Auth (OIDC via NITA-U IdP for the pilot) ─────────────────────────────
AUTH_MODE=oidc
# JWT_HS256_SECRET is still required as a fallback verifier path — must be
# unique per environment and rotated annually.
JWT_HS256_SECRET=                                # python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_ISSUER=landguard.ug
JWT_AUDIENCE=landguard-backend
OIDC_JWKS_URL=                                   # https://idp.nita.go.ug/.well-known/jwks.json

# ── Blockchain (Sepolia until the permissioned chain lands; see ADR-0003)
BLOCKCHAIN_PROVIDER=sepolia
SEPOLIA_RPC_URL=                                 # https://sepolia.infura.io/v3/<key>
SEPOLIA_CHAIN_ID=11155111
# PILOT PRACTICE: REGISTRAR_PRIVATE_KEY is the proposer (signer #4 in CUSTODY.md).
# This single key cannot anchor alone because MULTISIG_ENABLED=true requires
# three co-signers via MultiSigRegistrar.proposeAndConfirm.
# Production-ideal: move this key into Crane Cloud's secret manager + HSM,
# not in env. See infra/cranecloud/README.md §7.
REGISTRAR_PRIVATE_KEY=
CONTRACT_ADDRESS_FILE=/app/data_store/contract_address.json
ANCHOR_FLUSH_INTERVAL_SECONDS=300
ANCHOR_FLUSH_BATCH_SIZE=100

# ── Multi-sig 3-of-5 (REQUIRED for pilot+) ───────────────────────────────
MULTISIG_ENABLED=true

# ── NIRA (live in pilot) ─────────────────────────────────────────────────
NIRA_PROVIDER=live
NIRA_BASE_URL=                                   # https://api.nira.go.ug/v1 (pending)
NIRA_API_KEY=                                    # issued by NIRA on pilot MOU
NIRA_CACHE_TTL_SECONDS=86400

# ── PII encryption ───────────────────────────────────────────────────────
PII_ENCRYPTION_KEY=                              # base64-encoded 32 random bytes; rotated annually

# ── Rate limits (tighter than staging) ───────────────────────────────────
RATE_LIMIT_ANON=10/minute
RATE_LIMIT_AUTH=60/minute
RATE_LIMIT_ADMIN=300/minute
RATE_LIMIT_PUBLIC_VERIFY=20/minute

# ── Observability ────────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=                     # NITA-U / Crane Cloud OTel collector
OTEL_SERVICE_NAME=landguard-backend-pilot
PROMETHEUS_METRICS_ENABLED=true

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=https://landguard-frontend-pilot.cranecloud.ug,https://verify.landguard.ug

# ── Frontend public config ───────────────────────────────────────────────
BACKEND_URL=https://landguard-backend-pilot.cranecloud.ug
NEXT_PUBLIC_APP_NAME=LandGuard Uganda
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_DEFAULT_DISTRICT_ID=3
DEMO_TOKEN=                                      # leave blank in pilot — demo gate is closed in production
