# LandGuard Uganda — top-level orchestration env.
# Per-service env lives in backend/.env.example and frontend/.env.local.example.

# Caddy / TLS (only used with `--profile tls`).
LANDGUARD_HOST=localhost

# Optional Sepolia override; only needed for docker-compose.sepolia.yml.
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
# SEPOLIA_REGISTRAR_PRIVATE_KEY=0x...
