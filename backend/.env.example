# LandGuard Uganda — Backend Environment
# Copy to .env and adjust for your environment.

APP_ENV=development
APP_NAME=landguard-backend
LOG_LEVEL=INFO
DEMO_MODE=true

# --- Database ---
# Dev default is SQLite with WAL. For prod, set DB_BACKEND=postgres.
DB_BACKEND=sqlite
SQLITE_PATH=./data_store/landguard.db
POSTGRES_DSN=postgresql+asyncpg://landguard:landguard@postgres:5432/landguard

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
# In dev we use HS256 with a shared secret. In prod, set AUTH_MODE=oidc and configure JWKS_URL.
AUTH_MODE=dev
AUTH_REQUIRED=true
JWT_HS256_SECRET=change-me-dev-only-please-replace-in-prod-with-32-chars
JWT_ISSUER=landguard.ug
JWT_AUDIENCE=landguard-backend
OIDC_JWKS_URL=
FLAG_MULTI_TENANT=true

# --- Blockchain ---
# BLOCKCHAIN_PROVIDER: mock | anvil | sepolia
BLOCKCHAIN_PROVIDER=anvil
ANVIL_RPC_URL=http://anvil:8545
ANVIL_CHAIN_ID=31337
SEPOLIA_RPC_URL=
SEPOLIA_CHAIN_ID=11155111
# Pre-funded Anvil account 0 — replace with KMS-issued key in prod.
REGISTRAR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
CONTRACT_ADDRESS_FILE=./data_store/contract_address.json
ANCHOR_FLUSH_INTERVAL_SECONDS=300
ANCHOR_FLUSH_BATCH_SIZE=100

# --- NIRA (National ID Registration Authority) ---
NIRA_PROVIDER=mock
NIRA_BASE_URL=
NIRA_API_KEY=
NIRA_CACHE_TTL_SECONDS=86400

# --- Encryption ---
# 32-byte base64 key for AES-GCM at-rest encryption of NINs.
# In prod this comes from KMS/HSM, never from env.
PII_ENCRYPTION_KEY=dGhpc19pc19hX2RldmVsb3BtZW50X29ubHlfa2V5X3JlcGxhY2VfaXRfbm93

# --- Rate limits ---
RATE_LIMIT_ANON=10/minute
RATE_LIMIT_AUTH=60/minute
RATE_LIMIT_ADMIN=300/minute
RATE_LIMIT_PUBLIC_VERIFY=20/minute

# --- Observability ---
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=landguard-backend
PROMETHEUS_METRICS_ENABLED=true

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://frontend:3000
